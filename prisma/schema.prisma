// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model competitor {
  id        Int    @id() @default(autoincrement())
  username  String @unique()
  full_name String
  teamid    Int?
}

model problem {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  points      Int
}

model team {
  id           Int          @id() @default(autoincrement())
  name         String       @unique()
  team_members String?
  points       BigInt
}