{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "outDir": "dist",
    "lib": [
      "ESNext"
    ],
    "moduleResolution": "node",
    "isolatedModules": false,
    "noEmit": false,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "./server/*"
  ]
}