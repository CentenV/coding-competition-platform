{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "outDir": "dist",
    "lib": [
      "ESNext"
    ],
    "isolatedModules": false,
    "noEmit": false,
    "paths": {
      "@server/*": [
        "./server/*"
      ]
    }
  },
  "include": [
    "./server/*"
  ]
}